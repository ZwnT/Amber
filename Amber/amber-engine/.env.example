# Amber Engine — environment config
# Copy to .env and fill in values. All fields optional — they can also be set at runtime from the frontend.

# Server
HOST=0.0.0.0
PORT=8000

# Default LLM config (used by janitor memory incubation when no relay-level config is available)
DEFAULT_API_KEY=
DEFAULT_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL_ID=gpt-4o-mini

# Database (leave blank to use default SQLite path from config.py)
DATABASE_URL=
